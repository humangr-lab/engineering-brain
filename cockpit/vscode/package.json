{
  "name": "ontology-map",
  "displayName": "Ontology Map",
  "description": "Spatial code architecture visualization — see your codebase as an interactive graph",
  "version": "0.1.0",
  "publisher": "gustavoschneiter",
  "license": "MIT",
  "icon": "media/icon.png",
  "homepage": "https://github.com/gustavoschneiter/ontology-map",
  "repository": {
    "type": "git",
    "url": "https://github.com/gustavoschneiter/ontology-map"
  },
  "bugs": {
    "url": "https://github.com/gustavoschneiter/ontology-map/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "architecture",
    "visualization",
    "dependency-graph",
    "code-map",
    "tree-sitter"
  ],
  "activationEvents": [
    "onCommand:ontology-map.open",
    "onCommand:ontology-map.refresh"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ontology-map.open",
        "title": "Open Architecture View",
        "category": "Ontology Map"
      },
      {
        "command": "ontology-map.refresh",
        "title": "Refresh Graph",
        "category": "Ontology Map"
      }
    ],
    "keybindings": [
      {
        "command": "ontology-map.open",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ],
    "configuration": {
      "title": "Ontology Map",
      "properties": {
        "ontology-map.binaryPath": {
          "type": "string",
          "default": "ontology-map",
          "description": "Path to the ontology-map binary (defaults to searching PATH)"
        },
        "ontology-map.maxFiles": {
          "type": "number",
          "default": 5000,
          "description": "Maximum number of files to analyze"
        },
        "ontology-map.maxCommits": {
          "type": "number",
          "default": 200,
          "description": "Maximum git commits to analyze"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --sourcemap",
    "watch": "npm run build -- --watch",
    "package": "vsce package --no-dependencies",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
