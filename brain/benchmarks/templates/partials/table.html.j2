<table>
  <thead>
    <tr>
      {% for col in columns %}<th>{{ col }}</th>{% endfor %}
    </tr>
  </thead>
  <tbody>
    {% for row in rows %}
    <tr{% if row.highlight %} class="highlight-row"{% endif %}>
      {% for col in columns %}
      <td{% if row.mono is defined and col in row.mono %} class="mono"{% endif %}{% if row.winner is defined and col in row.winner %} class="winner mono"{% endif %}>{{ row[col] }}</td>
      {% endfor %}
    </tr>
    {% endfor %}
  </tbody>
</table>
