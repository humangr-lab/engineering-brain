<section id="cost">
  <h2>06. Cost/Benefit Analysis</h2>

  <p>Performance profiling across all systems to quantify the overhead of each approach.</p>

  {% if charts.latency_comparison %}
  <div class="chart-container">
    <img src="data:image/png;base64,{{ charts.latency_comparison }}" alt="Latency comparison" />
    <p class="chart-caption">Figure 7 — Query latency percentiles across systems.</p>
  </div>
  {% endif %}

  {% if charts.quality_vs_cost %}
  <div class="chart-container">
    <img src="data:image/png;base64,{{ charts.quality_vs_cost }}" alt="Quality vs cost" />
    <p class="chart-caption">Figure 8 — Quality (NDCG@10) vs. cost (median latency). Upper-left is ideal.</p>
  </div>
  {% endif %}

  <h3>System Performance Summary</h3>

  <table>
    <thead>
      <tr>
        <th>System</th>
        <th class="text-right">Latency p50</th>
        <th class="text-right">Latency p95</th>
        <th class="text-right">Latency p99</th>
        <th class="text-right">Tokens/Query</th>
        <th class="text-right">Memory</th>
        <th class="text-right">Setup Time</th>
      </tr>
    </thead>
    <tbody>
      {% for c in cost_profiles %}
      <tr>
        <td><strong>{{ c.system_name }}</strong></td>
        <td class="mono text-right">{{ "%.1f ms" | format(c.median_latency_ms) }}</td>
        <td class="mono text-right">{{ "%.1f ms" | format(c.p95_latency_ms) }}</td>
        <td class="mono text-right">{{ "%.1f ms" | format(c.p99_latency_ms) }}</td>
        <td class="mono text-right">{{ "%.0f" | format(c.avg_tokens_per_query) }}</td>
        <td class="mono text-right">{{ "%.1f MB" | format(c.peak_memory_mb) }}</td>
        <td class="mono text-right">{{ "%.2f s" | format(c.setup_time_s) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
