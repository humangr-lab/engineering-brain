<section id="comparison">
  <h2>03. Baseline Comparison</h2>

  <p>The Engineering Brain is evaluated against {{ systems_info | length - 1 }} baselines using the same knowledge base ({{ seed_count }} engineering rules across {{ layer_count }} layers).</p>

  <h3>Overall Results</h3>

  <div class="chart-container">
    <img src="data:image/png;base64,{{ charts.comparison_bar }}" alt="Baseline comparison bar chart" />
    <p class="chart-caption">Figure 1 — Retrieval quality metrics across all systems. Higher is better.</p>
  </div>

  <table>
    <thead>
      <tr>
        <th>System</th>
        <th class="text-right">NDCG@10</th>
        <th class="text-right">MRR</th>
        <th class="text-right">Recall@10</th>
        <th class="text-right">MAP</th>
        <th class="text-right">F1@10</th>
        <th class="text-right">Latency (ms)</th>
      </tr>
    </thead>
    <tbody>
      {% for name, sr in systems.items() %}
      <tr{% if sr.system_name == winner %} class="highlight-row"{% endif %}>
        <td><strong>{{ sr.system_name }}</strong></td>
        <td class="mono text-right{% if sr.system_name == winner %} winner{% endif %}">{{ "%.4f" | format(sr.aggregate.avg_ndcg_at_10) }}</td>
        <td class="mono text-right">{{ "%.4f" | format(sr.aggregate.avg_mrr) }}</td>
        <td class="mono text-right">{{ "%.4f" | format(sr.aggregate.avg_recall_at_10) }}</td>
        <td class="mono text-right">{{ "%.4f" | format(sr.aggregate.avg_map) }}</td>
        <td class="mono text-right">{{ "%.4f" | format(sr.aggregate.avg_f1_at_10) }}</td>
        <td class="mono text-right">{{ "%.1f" | format(sr.aggregate.avg_latency_ms) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <h3>Multi-Dimensional Comparison</h3>

  <div class="chart-container">
    <img src="data:image/png;base64,{{ charts.comparison_radar }}" alt="Radar chart comparison" />
    <p class="chart-caption">Figure 2 — Radar chart showing multi-dimensional quality comparison across all metrics.</p>
  </div>

  <h3>Performance by Category</h3>

  <div class="chart-container">
    <img src="data:image/png;base64,{{ charts.category_heatmap }}" alt="Category heatmap" />
    <p class="chart-caption">Figure 3 — NDCG@10 heatmap by query category and system.</p>
  </div>
</section>
