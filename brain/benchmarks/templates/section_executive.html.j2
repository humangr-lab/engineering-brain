<section id="executive">
  <h2>01. Executive Summary</h2>

  <div class="metric-cards">
    {% for card in executive_cards %}
    <div class="metric-card">
      <div class="label">{{ card.label }}</div>
      <div class="value">{{ card.value }}</div>
      {% if card.delta %}<div class="delta {{ card.delta_class }}">{{ card.delta }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>

  <div class="findings">
    <h3>Key Findings</h3>
    <ul>
      {% for finding in key_findings %}
      <li>{{ finding }}</li>
      {% endfor %}
    </ul>
  </div>

  {% if winner %}
  <p><strong>Best performing system:</strong> <span class="tag">{{ winner }}</span> across {{ winner_metrics }} of {{ total_metrics }} metrics.</p>
  {% endif %}
</section>
