<section id="appendix" class="page-break">
  <h2>Appendix: Per-Query Results</h2>

  <p class="text-muted text-small">Complete per-query metrics for the primary system ({{ primary_system }}).</p>

  <table>
    <thead>
      <tr>
        <th>Query ID</th>
        <th>Category</th>
        <th>Difficulty</th>
        <th class="text-right">NDCG@10</th>
        <th class="text-right">MRR</th>
        <th class="text-right">Recall@10</th>
        <th class="text-right">Precision@10</th>
        <th class="text-right">Results</th>
        <th class="text-right">Latency</th>
      </tr>
    </thead>
    <tbody>
      {% for q in per_query_results %}
      <tr>
        <td class="mono">{{ q.query_id }}</td>
        <td>{{ q.category }}</td>
        <td>{{ q.difficulty }}</td>
        <td class="mono text-right">{{ "%.4f" | format(q.metrics.ndcg_at_10) }}</td>
        <td class="mono text-right">{{ "%.4f" | format(q.metrics.mrr) }}</td>
        <td class="mono text-right">{{ "%.4f" | format(q.metrics.recall_at_10) }}</td>
        <td class="mono text-right">{{ "%.4f" | format(q.metrics.precision_at_10) }}</td>
        <td class="mono text-right">{{ q.metrics.result_count }}</td>
        <td class="mono text-right">{{ "%.1f ms" | format(q.metrics.latency_ms) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
